# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform plan files
*.tfplan
*.plan

# Ignore override files (used for local changes)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Dependency lock file (OPTIONAL: commit this if you want reproducible provider versions)
# .terraform.lock.hcl

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
terraform.tfvars
terraform.tfvars.json

# Sensitive variable files
*.auto.tfvars
*.auto.tfvars.json

# Local testing / editor artifacts
*.log
*.tmp
*.bak
*.swp
.DS_Store